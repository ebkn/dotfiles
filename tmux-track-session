#!/bin/bash
# tmux-track-session: Track tmux session changes for SSH auto-reconnect.
#
# Problem: autossh reconnects to a hardcoded remote tmux session name.
# If the user switches to a different session on the remote, the reconnect
# lands in the wrong session.
#
# Solution: Track session changes per connection ID via tty mapping.
#   1. On attach, map the client tty to the connection ID.
#   2. On session switch (tmux hook), save the new session name.
#   3. On reconnect, read the saved session name and attach to it.
#
# State directory: $XDG_STATE_HOME/tmux-track-session/
#   tty/      — {safe_tty} files containing conn_id
#   session/  — {conn_id} files containing last session name
#
# Subcommands:
#   attach <conn_id>                — attach to last-known session for conn_id
#   register <conn_id> <client_tty> — map client tty to conn_id (called by tmux)
#   update <client_tty> <session>   — save session for the conn_id at tty (hook)
#   cleanup <client_tty>            — remove tty mapping on detach (hook)

STATE_DIR="${XDG_STATE_HOME:-$HOME/.local/state}/tmux-track-session"
TTY_DIR="$STATE_DIR/tty"
SESSION_DIR="$STATE_DIR/session"
SELF="$HOME/.local/bin/tmux-track-session"

ensure_dirs() {
  mkdir -p "$TTY_DIR" "$SESSION_DIR"
}

safe_tty() {
  printf '%s' "$1" | tr '/' '_'
}

case "${1:-}" in
  attach)
    conn_id="${2:?usage: tmux-track-session attach <conn_id>}"
    ensure_dirs

    target="$conn_id"
    state_file="$SESSION_DIR/$conn_id"
    if [ -f "$state_file" ]; then
      saved=$(cat "$state_file")
      if tmux has-session -t "=$saved" 2>/dev/null; then
        target="$saved"
      fi
    fi

    # Attach (or create) the target session, then register the tty mapping.
    # #{client_tty} is expanded by tmux before passing to run-shell.
    exec tmux new-session -A -s "$target" \; \
      run-shell -b "'$SELF' register '$conn_id' '#{client_tty}'" \
      2>/dev/null
    # exec failed — fall through to login shell
    exec "${SHELL:-/bin/sh}" -l
    ;;

  register)
    conn_id="$2"
    client_tty="$3"
    # Guard: if tmux didn't expand #{client_tty}, skip silently
    [ -z "$client_tty" ] || [ "$client_tty" = '#{client_tty}' ] && exit 0
    ensure_dirs
    printf '%s' "$conn_id" > "$TTY_DIR/$(safe_tty "$client_tty")"
    ;;

  update)
    client_tty="$2"
    client_session="$3"
    [ -z "$client_tty" ] && exit 0
    tty_file="$TTY_DIR/$(safe_tty "$client_tty")"
    [ -f "$tty_file" ] || exit 0
    conn_id=$(cat "$tty_file")
    [ -n "$conn_id" ] && printf '%s' "$client_session" > "$SESSION_DIR/$conn_id"
    ;;

  cleanup)
    client_tty="$2"
    [ -z "$client_tty" ] && exit 0
    rm -f "$TTY_DIR/$(safe_tty "$client_tty")"
    ;;

  *)
    echo "Usage: tmux-track-session {attach|register|update|cleanup}" >&2
    exit 1
    ;;
esac
