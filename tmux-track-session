#!/bin/bash
# tmux-track-session: Track tmux session changes for SSH auto-reconnect.
#
# Problem: autossh reconnects to a hardcoded remote tmux session name.
# If the user switches to a different session on the remote, the reconnect
# lands in the wrong session.
#
# Solution: A per-connection monitor polls the client's current session
# and persists it. On reconnect, the saved session name is used.
# Unlike the previous hook-based approach (global client-session-changed +
# tty-to-conn_id mapping), this avoids race conditions from stale tty
# mappings when PTY numbers are reused on reconnect.
#
# State directory: $XDG_STATE_HOME/tmux-track-session/
#   session/  — {conn_id} files containing last session name
#   pid/      — {conn_id} files containing monitor PID
#
# Subcommands:
#   attach <conn_id>                — attach to last-known session for conn_id
#   monitor <conn_id> <client_tty>  — poll session changes (called by tmux)

STATE_DIR="${XDG_STATE_HOME:-$HOME/.local/state}/tmux-track-session"
SESSION_DIR="$STATE_DIR/session"
PID_DIR="$STATE_DIR/pid"
SELF="$HOME/.local/bin/tmux-track-session"

ensure_dirs() {
  mkdir -p "$SESSION_DIR" "$PID_DIR"
}

case "${1:-}" in
  attach)
    conn_id="${2:?usage: tmux-track-session attach <conn_id>}"
    ensure_dirs

    # Migrate: clean up tty mapping directory from previous implementation
    [ -d "$STATE_DIR/tty" ] && rm -rf "$STATE_DIR/tty"

    # Kill any stale monitor for this conn_id from a previous connection
    pid_file="$PID_DIR/$conn_id"
    if [ -f "$pid_file" ]; then
      kill "$(cat "$pid_file")" 2>/dev/null
      rm -f "$pid_file"
    fi

    target="$conn_id"
    state_file="$SESSION_DIR/$conn_id"
    if [ -f "$state_file" ]; then
      saved=$(cat "$state_file")
      if tmux has-session -t "=$saved" 2>/dev/null; then
        target="$saved"
      fi
    fi

    # Attach (or create) the target session, then start a monitor.
    # #{client_tty} is expanded by tmux before passing to run-shell.
    exec tmux new-session -A -s "$target" \; \
      run-shell -b "'$SELF' monitor '$conn_id' '#{client_tty}'" \
      2>/dev/null
    # exec failed — fall through to login shell
    exec "${SHELL:-/bin/sh}" -l
    ;;

  monitor)
    conn_id="$2"
    client_tty="$3"
    # Guard: if tmux didn't expand #{client_tty}, skip silently
    [ -z "$client_tty" ] || [ "$client_tty" = '#{client_tty}' ] && exit 0
    ensure_dirs

    # Record monitor PID so attach can kill us on reconnect
    printf '%s' "$$" > "$PID_DIR/$conn_id"

    # Record initial client PID to detect tty reuse (graceful degradation
    # if the lookup fails — the PID check is simply skipped)
    my_pid=$(tmux list-clients -f "#{==:#{client_tty},$client_tty}" \
      -F '#{client_pid}' 2>/dev/null)

    prev=""
    while true; do
      # Check client is still alive and is the same client we started with
      info=$(tmux list-clients -f "#{==:#{client_tty},$client_tty}" \
        -F '#{client_pid} #{client_session}' 2>/dev/null)
      [ -z "$info" ] && break

      current_pid="${info%% *}"
      session="${info#* }"

      # If client PID changed, our client was replaced (tty reuse) — stop
      if [ -n "$my_pid" ] && [ "$current_pid" != "$my_pid" ]; then
        break
      fi

      if [ "$session" != "$prev" ]; then
        printf '%s' "$session" > "$SESSION_DIR/$conn_id"
        prev="$session"
      fi
      sleep 2
    done
    rm -f "$PID_DIR/$conn_id"
    ;;

  *)
    echo "Usage: tmux-track-session {attach|monitor}" >&2
    exit 1
    ;;
esac
