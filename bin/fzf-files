#!/usr/bin/env bash
# fzf-files: list git-changed files first, then all remaining files (deduped).
# Extra arguments are passed through to rg (e.g. --glob "!dir/**").
# Falls back to plain rg --files outside a git repo.
#
# --label: prepend tab-delimited [ label ] to git-changed files.
#   With fzf --tabstop=1, the tab renders as a single space:
#     [ staged   ] path
#     [ unstaged ] path
#     [ <hash>   ] path
#     path                ← no label, no leading space
#   Priority: staged > unstaged > committed (first label wins per file).

set -euo pipefail

label_mode=false
if [[ "${1-}" == "--label" ]]; then
  label_mode=true
  shift
fi

rg_base=(rg --files --hidden --smart-case --glob='!.git/*')

if git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
  if "$label_mode"; then
    # Build labeled list: [ label    ]\tpath
    # Use HASH: prefix marker to distinguish commit hashes from filenames.
    changed=$(
      {
        git diff --relative --name-only --cached \
          | awk '{printf "[ staged   ]\t%s\n", $0}'
        git diff --relative --name-only \
          | awk '{printf "[ unstaged ]\t%s\n", $0}'
        git log --relative --name-only --pretty='format:HASH:%h' -5 \
          | awk '/^HASH:/{hash=$0; sub(/^HASH:/,"",hash); next} NF{printf "[ %-8s ]\t%s\n", hash, $0}'
      }
    )

    # Output changed files (existing only, first label wins per path), then rg files
    {
      while IFS=$'\t' read -r lbl f; do
        [[ -f "$f" ]] && printf '%s\t%s\n' "$lbl" "$f"
      done <<< "$changed"
      "${rg_base[@]}" "$@"
    } | awk -F'\t' '!seen[$NF]++'
  else
    # Plain mode: no labels
    changed=$(
      {
        git diff --relative --name-only
        git diff --relative --name-only --cached
        git log --relative --name-only --pretty=format: -5
      } | awk 'NF && !seen[$0]++'
    )

    {
      while IFS= read -r f; do
        [[ -f "$f" ]] && printf '%s\n' "$f"
      done <<< "$changed"
      "${rg_base[@]}" "$@"
    } | awk '!seen[$0]++'
  fi
else
  "${rg_base[@]}" "$@"
fi
