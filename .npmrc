# Supply-chain hardening: only install package versions that have been
# published for at least N days. Most malicious packages are detected and
# unpublished within hours-to-days, so this delay greatly reduces the chance
# of installing a compromised release.
#
# Unit is days and the key is npm-specific: pnpm (~/.yarnrc.yml sibling is
# pnpm's config.yaml) uses minutes via minimumReleaseAge, yarn uses minutes via
# npmMinimalAgeGate (~/.yarnrc.yml), bun uses seconds. Each reads its own key —
# none inherits this one — so the 3-day window is set in all three places.
# Requires npm >= 11.10.0 (the release that added min-release-age); older npm
# silently ignores this line.
min-release-age=3

# Exact version pins: record `1.2.3`, not `^1.2.3`, when adding a dependency.
# A caret range lets `npm install` silently pull a newer patch/minor that may be
# freshly compromised; an exact pin plus lockfile means an upgrade is always a
# deliberate, reviewable edit. Mirrors yarn defaultSemverRangePrefix:"" and pnpm
# savePrefix:''. Only affects newly added deps, not existing ranges.
save-exact=true

# Do not run lifecycle scripts (a dependency's install/postinstall is the most
# common malware execution vector). Mirrors yarn enableScripts:false and pnpm
# ignoreScripts:true. NOTE: npm has no per-package allowlist (unlike pnpm's
# onlyBuiltDependencies), so this is all-or-nothing — packages that build native
# addons via postinstall (esbuild, sharp, better-sqlite3, ...) will not build.
# Run those installs with `npm install --foreground-scripts` / `--ignore-scripts=false`.
ignore-scripts=true
